# Stock Agent Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# API KEYS (Required)
# =============================================================================

# Polygon.io API key for stock data
# Get from: https://polygon.io/dashboard
POLYGON_API_KEY=your_polygon_api_key_here

# =============================================================================
# FIREBASE CONFIGURATION (Required for notifications)
# =============================================================================

# Firebase project configuration
# Get from: Firebase Console > Project Settings > General
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef123456789

# Firebase Cloud Messaging VAPID key
# Get from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
FIREBASE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Host and port configuration
HOST=0.0.0.0
PORT=8080

# Application behavior
GENERATE_MARKET_SUMMARY=true

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database file location (inside container)
DATABASE_PATH=/app/data/users.db

# Data directory
DATA_DIR=/app/data

# =============================================================================
# FIREBASE CREDENTIALS FILE
# =============================================================================

# Path to Firebase service account credentials JSON file
# This should be mounted into the container or built into the image
FIREBASE_CREDS_PATH=/app/firebase_creds.json

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Development flags (set to false for production)
DEBUG=false

# =============================================================================
# DEVELOPMENT OVERRIDES (Optional)
# =============================================================================

# Use these for development/testing environments
# DEV_HOST=127.0.0.1
# DEV_PORT=3000
# DEV_GENERATE_SUMMARY=false

# =============================================================================
# EXAMPLE VALUES FOR REFERENCE
# =============================================================================

# Example Firebase configuration (replace with your actual values):
# FIREBASE_API_KEY=AIzaSyAYGsRBnhBJ36INWy4p0j_wFjR6qLi8hxw
# FIREBASE_AUTH_DOMAIN=stock-agent-f37c2.firebaseapp.com
# FIREBASE_PROJECT_ID=stock-agent-f37c2
# FIREBASE_STORAGE_BUCKET=stock-agent-f37c2.firebasestorage.app
# FIREBASE_MESSAGING_SENDER_ID=691939234714
# FIREBASE_APP_ID=1:691939234714:web:c719ebaa3e0b1b27e92023
